<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="context.playlist.manager" name="Playlist Manager" version="1.0.1" provider-name="AcidZab">
    <requires>
        <import addon="xbmc.python" version="3.0.1"/>
        <import addon="script.module.zab.commons" version="1.0.0"/>
    </requires>
    <extension point="kodi.context.item">
        <menu id="kodi.core.main">
            <item library="append.py">
                <label>Aggiungi ad una playlist</label>
                <visible>Container.Content(songs)</visible>
            </item>
            <item library="remove.py">
                <label>Rimuovi dalla playlist</label>
                <visible>Container.Content(songs) + String.Contains(Container.FolderPath,playlists)</visible>
            </item>
        </menu>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Gestore playlist</summary>
        <description>Add-on per permettere la gestione delle playlist su Kodi</description>
        <platform>all</platform>
        <license>GNU General Public License, v2</license>
        <email>gigi@gigi.com</email>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>